# ==== Closed-source providers ====
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=...
# Google Gemini API key (either GEMINI_API_KEY or GOOGLE_API_KEY)
GEMINI_API_KEY=...
GOOGLE_API_KEY=...

# Azure OpenAI (if using Azure OpenAI directly)
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
OPENAI_API_VERSION=2024-10-21

# Azure AI Inference (GitHub Models free-tier)
GITHUB_TOKEN=github_pat_...

# Mistral
MISTRAL_API_KEY=...

# ==== Hugging Face ====
HUGGINGFACEHUB_API_TOKEN=hf_...

# ==== Local Ollama ====
# No key required; ensure the server runs at http://localhost:11434
